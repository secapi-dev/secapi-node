{
  "name": "secapi-node",
  "version": "0.1.0",
  "description": "Official TypeScript/Node SDK for secapi.dev - SEC filings, financials, insider transactions, and institutional holdings.",
  "type": "module",
  "license": "MIT",
  "author": "SEC API <support@secapi.dev>",
  "homepage": "https://secapi.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/secapi-dev/secapi-node.git"
  },
  "bugs": {
    "url": "https://github.com/secapi-dev/secapi-node/issues"
  },
  "keywords": [
    "sec",
    "edgar",
    "filings",
    "financials",
    "xbrl",
    "insider",
    "13f",
    "api",
    "sdk",
    "finance"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
